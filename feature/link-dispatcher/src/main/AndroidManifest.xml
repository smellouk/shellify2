<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity
            android:name="io.shellify.app.presentation.linkdispatcher.LinkDispatcherActivity"
            android:exported="true"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Shellify.Transparent">

            <!-- INTG-05: Share sheet text/plain handler -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- INTG-06: shellify://open deep link — direct handler on dispatcher. NO autoVerify. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="shellify" android:host="open" />
            </intent-filter>

        </activity>
    </application>
</manifest>
