    <!-- Consent screen -->
    <string name="consent_title">Before you start</string>
    <string name="consent_subtitle">Please read the following carefully. By continuing, you acknowledge and agree to these terms.</string>
    <string name="consent_section_what_title">What Shellify does</string>
    <string name="consent_what_1">Allows users to create isolated web-based app containers on their own device</string>
    <string name="consent_what_2">Functions as a web-viewing tool that loads websites selected by the user</string>
    <string name="consent_what_3">All browsing data and app data remain stored locally on the user\'s device unless the user interacts directly with a third-party website or service</string>
    <string name="consent_what_4">Shellify may allow users to locally share user-selected website links or app configurations through standard operating-system sharing features. Such sharing is initiated solely by users and is not transmitted, stored, indexed, or moderated by Shellify</string>
    <string name="consent_section_not_title">What Shellify does not do</string>
    <string name="consent_not_1">We do not own, host, control, monitor, modify, or endorse third-party websites or services</string>
    <string name="consent_not_2">We do not intentionally collect, store, or transmit your browsing activity or the content you access through third-party websites</string>
    <string name="consent_not_3">We are not affiliated with any third-party website unless explicitly stated</string>
    <string name="consent_not_4">We do not guarantee the legality, security, availability, or reliability of any third-party website or content</string>
    <string name="consent_not_5">Shellify is a general-purpose user-controlled tool and does not encourage, promote, or facilitate unlawful activity or unauthorized access to services</string>
    <string name="consent_section_acceptable_title">Acceptable use</string>
    <string name="consent_acceptable_intro">You agree not to use Shellify to:</string>
    <string name="consent_acceptable_1">Violate any applicable law or regulation</string>
    <string name="consent_acceptable_2">Infringe intellectual property rights or copyrights</string>
    <string name="consent_acceptable_3">Bypass paywalls, access restrictions, authentication systems, or digital protections</string>
    <string name="consent_acceptable_4">Distribute malware, harmful code, or unauthorized content</string>
    <string name="consent_acceptable_5">Engage in fraud, harassment, abuse, or other unlawful activity</string>
    <string name="consent_acceptable_6">Impersonate individuals, organizations, brands, or official services</string>
    <string name="consent_acceptable_7">Share or distribute links, app configurations, backup files, or session data intended to facilitate phishing, credential theft, malware distribution, impersonation, copyright infringement, or other unlawful activity</string>
    <string name="consent_acceptable_reserve">We reserve the right to update, suspend, restrict, or discontinue Shellify or specific features at any time, particularly in cases involving security, abuse prevention, legal compliance, or violations of these terms.</string>
    <string name="consent_section_responsibility_title">Your responsibility</string>
    <string name="consent_responsibility_1">You are responsible for the websites you access and the content you use through Shellify</string>
    <string name="consent_responsibility_2">You are responsible for complying with the terms, policies, and applicable laws relating to any third-party website or service you use</string>
    <string name="consent_responsibility_3">You must be at least 13 years old, or the minimum digital age required in your jurisdiction</string>
    <string name="consent_responsibility_4">You are responsible for protecting backup files and passwords — backups may contain authenticated session data for third-party services</string>
    <string name="consent_responsibility_5">You are responsible for ensuring that use of exported or restored session data complies with applicable third-party terms and policies</string>
    <string name="consent_section_legal_title">Limitation of liability</string>
    <string name="consent_legal_intro">Shellify is provided "as is" and "as available" without warranties of any kind. To the maximum extent permitted by law, we disclaim liability for:</string>
    <string name="consent_legal_1">Third-party content or services</string>
    <string name="consent_legal_2">User activity conducted through the app</string>
    <string name="consent_legal_3">Data loss, security incidents, or service interruptions</string>
    <string name="consent_legal_4">Damages arising from the use of third-party websites or services</string>
    <string name="consent_section_privacy_title">Privacy</string>
    <string name="consent_privacy_desc">Shellify does not intentionally collect, store, or transmit your browsing activity. Browsing activity is processed locally on the device. Please review our Privacy Policy and Terms of Service for full details.</string>
