<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="com.android.launcher.action.INSTALL_SHORTCUT" />
        </intent>
    </queries>

    <application
        android:name=".ShellifyApplication"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Shellify"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <!-- Main Compose UI -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Shellify.Splash"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="shellify"
                    android:host="add" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="https"
                    android:host="shellify.app"
                    android:pathPrefix="/add" />
            </intent-filter>
        </activity>

        <!-- WebViewActivity, ShortcutActivity, and LinkDispatcherActivity are declared in their respective feature module manifests -->

        <!-- BackgroundNotificationService: keeps GeckoRuntime alive for background push notifications.
             foregroundServiceType=specialUse is required because there is no standard category
             for "keep service worker alive" (FOREGROUND_SERVICE_SPECIAL_USE, API 34+). -->
        <service
            android:name=".presentation.webview.BackgroundNotificationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keep PWA service workers alive so push notifications arrive while the WebView is closed" />
        </service>

        <!-- INTG-09: App Links for https://shellify.app/open — autoVerify=true because assetlinks.json is deployed.
             This must live in the app manifest (not feature module) so the merged manifest is verified by Android. -->
        <activity
            android:name="io.shellify.app.presentation.linkdispatcher.LinkDispatcherActivity"
            android:exported="true">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="shellify.app"
                    android:pathPrefix="/open" />
            </intent-filter>
        </activity>

        <!-- Required by createComposeRule() in Robolectric unit tests -->
        <activity
            android:name="androidx.activity.ComponentActivity"
            android:exported="false" />

        <!-- FileProvider for sharing icons -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
