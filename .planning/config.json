{
  "version": "1.0",
  "mode": "yolo",
  "granularity": "coarse",
  "parallelization": true,
  "commit_docs": true,
  "model_profile": "balanced",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": false,
    "auto_advance": false,
    "use_worktrees": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "subagent_timeout": 600,
    "inline_plan_threshold": 3
  },
  "git": {
    "base_branch": "main",
    "phase_branch_template": "feature/phase-{phase}-{slug}",
    "milestone_branch_template": "release/{milestone}",
    "squash": true
  },
  "project": {
    "name": "Shellify",
    "code": "SHE",
    "path": ".planning/PROJECT.md"
  }
}
